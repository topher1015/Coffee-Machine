MENU = {
    "espresso": {
        "ingredients": {
            "water": 50,
            "coffee": 18,
        },
        "cost": 1.5,
    },
    "latte": {
        "ingredients": {
            "water": 200,
            "milk": 150,
            "coffee": 24,
        },
        "cost": 2.5,
    },
    "cappuccino": {
        "ingredients": {
            "water": 250,
            "milk": 100,
            "coffee": 24,
        },
        "cost": 3.0,
    }
}

resources = {
    "water": 300,
    "milk": 200,
    "coffee": 100,
}

machine_on = True
money = 0

# ask what the user would like
def what_is_order():
    return input("What would you like? (espresso/latte/cappuccino): ").lower()

#check if sufficient resources
def check_resource(order):
    for item in MENU[order]["ingredients"]:
        if resources[item] < MENU[order]["ingredients"][item]:
            print(f"Sorry, there is not enough {item}.")
            return False
        return True

#take coins
def insert_coin():
    total_quarter = float(input('how many quarters?'))
    total_dime = float(input('how many dimes?'))
    total_nickel = float(input('how many nickels?'))
    total_penny = float(input('how many pennies?'))
    total_money = total_quarter * .25 + total_dime * .10 + total_nickel * .05 + total_penny * .01
    return total_money

#check if coin transaction successful
def enough_money(order, total_money):
    global money
    cost = MENU[order]["cost"]
    if total_money >= cost:
        change = round(total_money - cost, 2)
        money += cost
        for item in MENU[order]["ingredients"]:
            resources[item] -= MENU[order]["ingredients"][item]
        if change > 0:
            print(f"Here is ${change} in change.")
        print(f"Here is your {order}. Enjoy!")
    #not enough money 
    else:
        print("Sorry that's not enough money. Money refunded.")

#machine is on continue to ask for order
while machine_on:
    order = what_is_order()
    #secret code to turn off machine
    if order == "off":
        machine_on = False
    #code for getting resource information
    elif order == "report":
            print(f"Water: {resources['water']}")
            print(f"Milk: {resources['milk']}")
            print(f"Coffee: {resources['coffee']}")
            print(f"Money: ${money}")
    #make coffee
    elif order in MENU:
        if check_resource(order):
            total = insert_coin()
            enough_money(order, total)
    #wrong entry
    else:
        print("Sorry, that is not a valid option.")
